<?xml version="1.0" encoding="utf-8"?>
<!--
  이 파일은 실행파일 옆에 반드시 함께 있어야 합니다 (파일명: "인증서 이사 도우미.exe.config").
  loadFromRemoteSources=true :
    깃허브에서 ZIP 으로 받아 압축을 풀면 Windows 가 모든 파일에 "인터넷에서 받음" 표시
    (Mark of the Web / Zone.Identifier)를 붙입니다. 이 표시가 붙은 app\lib\WebView2 DLL 을
    Assembly.LoadFrom 으로 불러올 때 .NET 이 로드를 거부해(FileLoadException, HRESULT 0x80131515)
    프로그램이 아무 화면도 없이 죽습니다. 이 설정이 그 차단을 풀어 정상 로드되게 합니다.
    (설정 파일 자체는 어셈블리가 아니라 표시가 붙어 있어도 영향 없음.)
-->
<configuration>
  <runtime>
    <loadFromRemoteSources enabled="true" />
  </runtime>
</configuration>
